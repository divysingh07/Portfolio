---
import BaseLayout from "../layouts/BaseLayout.astro";

const tagline = "Consulting & Analytics";

const summary =
  "Results-driven analyst with experience at Capgemini, specializing in business analysis and data analytics. Contributed to AI-enabled analytics initiatives that improved operational efficiency and decision-making. Strong analytical rigor, clear stakeholder communication, and the ability to translate complex data into actionable insights.";

const experience = [
  {
    org: "Capgemini",
    leftMeta: ["Atlanta, GA", "Jun 2025 – Aug 2025"],
    role: "Data Consulting Intern",
    photos: [
  `${import.meta.env.BASE_URL}CapG1.jpg`,
  `${import.meta.env.BASE_URL}CapG2.jpg`
],
    bullets: [
      "Led a strategic case study on integrating AI solutions to drive business growth and operational efficiency.",
      "Delivered executive-level presentations showcasing ROI analysis, projected cost savings, and productivity enhancements from AI adoption.",
      "Analyzed support ticket workflows with a client account to gather automation requirements.",
      "Designed specs for an AI agent to automate end-to-end ticket management, reducing manual workload."
    ],
  },
  {
    org: "Virginia Department of Taxation",
    leftMeta: ["Richmond, VA", "Jun 2024 – Aug 2024"],
    role: "Software Developing Intern",
    bullets: [
      "Collaborated with cross-functional teams to refine business requirements for software solutions.",
      "Conducted data-driven analyses to optimize tax computation processes.",
      "Maintained documentation, including Functional Design Documents (FDDs).",
      "Used SQL and Java to extract insights and support decision-making."
    ],
  },
  {
    org: "Mason Investment Club",
    leftMeta: ["Williamsburg, VA", "Aug 2022 – Present"],
    role: "Financial Analyst",
    bullets: [
      "Conducted market research and financial analysis to identify investment opportunities.",
      "Presented actionable insights through reports and visualizations.",
      "Built financial models to evaluate stock performance and forecast trends."
    ],
  },
];

const education = {
  school: "William & Mary",
  detail: "B.A. Candidate in Economics and Data Science",
  gpa: "3.7",
};

const certifications = [
  "Financial Mathematics for Financial Markets — Train the Street (2024)",
  "Unlocking Investment and Finance in Emerging Markets — edX (2024)",
  "Capital Markets and Corporate Funding — Train the Street (2024)",
  "GitHub Copilot Practitioner — Capgemini (2025)"
];
---

<BaseLayout title="Divyansh Singh | Portfolio">
  <div class="pageShell">
    <!-- Make sure this file exists in /public exactly as written -->
    <img class="longBackground" src={`${import.meta.env.BASE_URL}background.jpg`} alt="" aria-hidden="true" />

    <!-- HOME -->
    <section id="home" class="section">
      <div class="card heroIntro">

        <div class="homeCenter">
          <img class="pfpHome" src={`${import.meta.env.BASE_URL}profile_photo.png`} alt="Divyansh Singh" />

          <div class="nameDecor" aria-hidden="true">
            <span class="decorLine"></span>
            <span class="decorDiamond"></span>
            <span class="decorDiamond"></span>
            <span class="decorLine"></span>
          </div>

         <h1 class="name">DIVYANSH SINGH</h1>

<p class="sub">Consulting & Analytics</p>

<p class="tagline">
Turning data, strategy, and technology into practical business solutions.
</p>
        </div>

        <div class="nextLink">
          <a href="#experience" aria-label="Next section">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 16.5a1 1 0 0 1-.7-.29l-6-6a1 1 0 1 1 1.4-1.42L12 13.59l5.3-4.8a1 1 0 1 1 1.4 1.42l-6 6a1 1 0 0 1-.7.29z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="section">
      <div class="card reveal">
        <p class="sectionLabel">Experience</p>
      <div class="summaryBlock">
  <h2 class="section-title">Professional Summary</h2>
  <p class="lead">{summary}</p>
</div>

        <div style="height:18px"></div>

        {experience.map((job) => (
          <div class="two-col">
            <div>
              <p class="org">{job.org}</p>
              {job.leftMeta.map((m) => (
                <p class="meta">{m}</p>
              ))}
            </div>

            <div>
              <p class="role">{job.role}</p>
              <ul class="bullets">
                {job.bullets.map((b) => <li>{b}</li>)}
              </ul>

              {job.photos && (
                <div class="jobPhotos">
                  {job.photos.map((p) => (
                    <img src={p} alt={`${job.org} experience photo`} />
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}

        <div class="nextLink">
          <a href="#education" aria-label="Next section">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 16.5a1 1 0 0 1-.7-.29l-6-6a1 1 0 1 1 1.4-1.42L12 13.59l5.3-4.8a1 1 0 1 1 1.4 1.42l-6 6a1 1 0 0 1-.7.29z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- EDUCATION -->
  <section id="education" class="section">
  <div class="card reveal">

    <p class="sectionLabel">Education and Certifications</p>

    <!-- College subsection -->
    <p class="subSection">College</p>

    <div class="two-col" style="border-top:none; padding-top:0;">
      <div>
        <p class="org">{education.school}</p>
        <p class="meta" style="margin:0">{education.detail}</p>
      </div>

      <div>
        <p class="role" style="margin:0 0 6px;">GPA</p>
        <p class="meta" style="margin:0">{education.gpa}</p>
      </div>
    </div>

    <div style="height:22px"></div>

    <!-- Certifications subsection -->
    <p class="subSection">Certifications</p>

<div class="certTags">
  {certifications.map((c) => (
    <span class="certTag">{c}</span>
  ))}
</div>

    <div class="nextLink">
      <a href="#outside" aria-label="Next section">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 16.5a1 1 0 0 1-.7-.29l-6-6a1 1 0 1 1 1.4-1.42L12 13.59l5.3-4.8a1 1 0 1 1 1.4 1.42l-6 6a1 1 0 0 1-.7.29z"/>
        </svg>
      </a>
    </div>

  </div>
</section>
<!-- OUTSIDE THE OFFICE -->
<section id="outside" class="section">
  <div class="card reveal">

    <p class="sectionLabel">Beyond the Office</p>

    <div class="outsideHeader">
      <img class="soccerPhoto" src={`${import.meta.env.BASE_URL}soccer.jpeg`} alt="Youth soccer tournament medal" />

      <h2 class="outsideTitle">Soccer</h2>

      <p class="outsideIntro">
        A lifelong passion that has shaped my discipline, teamwork, and competitive mindset.
      </p>
    </div>

    <div class="timeline">
      <div class="timelineItem">
        <div class="timelineYear">2012</div>
        <div class="timelineContent">
          Began playing organized youth soccer and developed an early passion for the sport, learning the fundamentals of teamwork and discipline.
        </div>
      </div>

      <div class="timelineItem">
        <div class="timelineYear">2014</div>
        <div class="timelineContent">
          Joined competitive club teams and began participating in regional leagues and tournaments while committing to consistent training and team development.
        </div>
      </div>

      <div class="timelineItem">
        <div class="timelineYear">2017</div>
        <div class="timelineContent">
          Competed in national and international tournaments including the Dallas Cup. Honored to be part of the #1 ranked team in the state while competing against elite teams from across the country and internationally.
        </div>
      </div>

      <div class="timelineItem">
        <div class="timelineYear">2018–2022</div>
        <div class="timelineContent">
          Played varsity high school soccer while balancing athletics with academics. Developed leadership, resilience, communication, and the ability to perform under pressure in a competitive team environment.
        </div>
      </div>

      <div class="timelineItem">
        <div class="timelineYear">2022–Present</div>
        <div class="timelineContent">
          Continue playing through intramural matches, pickup games, and recreational leagues while at William & Mary. Soccer remains an important outlet for competition, teamwork, and staying active.
        </div>
      </div>
    </div>

    <div class="nextLink">
      <a href="#connect" aria-label="Next section">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 16.5a1 1 0 0 1-.7-.29l-6-6a1 1 0 1 1 1.4-1.42L12 13.59l5.3-4.8a1 1 0 1 1 1.4 1.42l-6 6a1 1 0 0 1-.7.29z"/>
        </svg>
      </a>
    </div>

  </div>
</section>
    <!-- CONNECT -->
    <section id="connect" class="section">
      <div class="card reveal">
        <p class="sectionLabel">Connect</p>
        <h2 class="section-title">Let’s connect</h2>

        <div class="linkedinConnect">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.476-.9 1.637-1.85 3.368-1.85 3.6 0 4.268 2.37 4.268 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM6.814 20.452H3.86V9h2.954v11.452z"/>
          </svg>

          <div>
            <p class="role" style="margin-bottom:6px;">LinkedIn</p>
            <p class="meta" style="margin:0 0 10px;">
              For professional networking and opportunities, LinkedIn is the best place to reach me.
            </p>
            <a class="linkedinButton" href="https://www.linkedin.com/in/divyansh-singh-0214112a5" target="_blank" rel="noreferrer">
              View My LinkedIn
            </a>
          </div>
        </div>

        <h3 class="role" style="margin:24px 0 10px;">Send a message</h3>

        <form class="contactForm" action="https://formspree.io/f/xdawnvon" method="POST">
          <label><span>Name</span><input name="name" type="text" required /></label>
          <label><span>Email</span><input name="email" type="email" required /></label>
          <label><span>Message</span><textarea name="message" rows="6" required></textarea></label>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </section>
  </div>
  <script is:inline>
  const revealEls = document.querySelectorAll('.reveal');

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, {
    threshold: 0.18
  });

  revealEls.forEach((el) => revealObserver.observe(el));
</script>
</BaseLayout>